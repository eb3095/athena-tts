# Athena TTS Agent Configuration
# Copy to /etc/athena/tts.env

# Athena server URL (agent connects here to poll for jobs)
ATHENA_SERVER_URL=https://your-athena-server.example.com

# Agent key - must match AGENT_KEY configured in athena-server
AGENT_KEY=

# How often to poll athena-server for tasks (seconds)
POLL_INTERVAL=1.0
